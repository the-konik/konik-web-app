# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Common errors:
# - P1013 "empty host" → URL is broken. Check for typos, missing @HOST, or a password
#   with special characters (@ : / # ? &) — those must be URL-encoded in USER/PASSWORD.
# - P1000 "Authentication failed" → USER/PASSWORD don't match your Postgres server.
#
# Local with Docker (see docker-compose.yml in project root):
#   DATABASE_URL="postgresql://konik:konik_dev_password@localhost:5432/konik?schema=public"
#
# Cloud (Neon, Supabase, Vercel Postgres): copy the full connection string they give you.
DATABASE_URL="postgresql://konik:konik_dev_password@localhost:5432/konik?schema=public"

# Optional: first super admin (npm run db:seed). Defaults: konik.superadmin@mail.com / Password@123
# SEED_SUPERADMIN_EMAIL="konik.superadmin@mail.com"
# SEED_SUPERADMIN_PASSWORD="Password@123"

# NextAuth
AUTH_SECRET="generate-a-secret-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth (optional — leave blank to hide/disable in UI if you branch on env)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Webhook events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Enable Customer portal: Stripe Dashboard → Settings → Billing → Customer portal (for /api/billing/portal)

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (optional — see docs/INTEGRATIONS.md)
# RESEND_API_KEY=""
# EMAIL_FROM="KONIK <orders@yourdomain.com>"

# Optional AI (future — server only, never NEXT_PUBLIC_)
# OPENAI_API_KEY=""
# AI_RECOMMENDATIONS_ENABLED="false"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
