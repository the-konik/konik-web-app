generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Linked OAuth provider account (Google, GitHub, etc.) for a User.
model Account {
  /// Primary key.
  id                String  @id @default(cuid())
  /// Owner user.
  userId            String
  /// Auth.js account type (e.g. "oauth").
  type              String
  /// Provider id (e.g. "google").
  provider          String
  /// Provider’s unique id for this account.
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// Database-backed session (if used); JWT strategy may still create rows depending on config.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Email verification / password reset tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Registered person (or elevated guest row). Central actor for orders, tools, subscriptions.
model User {
  /// Internal id (cuid).
  id               String           @id @default(cuid())
  /// Engagement score for stage-based homepage (COLD/WARM/HOT).
  engagementScore  Int              @default(0)
  /// Display name (full).
  name             String?
  /// First name.
  firstName        String?
  /// Last name / surname.
  surname          String?
  /// Date of birth (birthday discount).
  dateOfBirth      DateTime?
  /// Whether user has claimed the 40% first-purchase discount.
  firstPurchaseDiscountClaimed Boolean @default(false)
  /// Login identifier; unique when set.
  email            String?          @unique
  /// When the email was verified (NextAuth / app flow).
  emailVerified    DateTime?
  /// Avatar URL (OAuth or uploaded).
  image            String?
  /// Bcrypt hash for credentials provider; null for OAuth-only users.
  password         String?
  /// Record creation time.
  createdAt        DateTime         @default(now())
  /// Last update time.
  updatedAt        DateTime         @updatedAt
  /// Stripe Customer id for checkout, subscriptions, and portal.
  stripeCustomerId String?          @unique
  /// Structured preferences for recommendations / UX (not for secrets).
  /// Future: sync with ML feature store or embedding service ids.
  aiPreferences    Json?
  /// Opaque reference to an external vector / RAG store document (e.g. Pinecone id).
  /// Keeps DB small; actual vectors live in the AI service.
  aiProfileRef     String?          @db.VarChar(255)
  /// Arbitrary JSON: marketing consent, locale, feature flags, A/B buckets.
  metadata         Json?
  /// Admin panel permissions. Null = not staff (`UserRole.ADMIN` still treated as SUPER_ADMIN for legacy accounts).
  staffRole        StaffRole?
  /// Role / tier for authorization and UX (see `UserRole`).
  role             UserRole         @default(USER)
  accounts         Account[]
  orders           Order[]
  sessions         Session[]
  subscriptions    Subscription[]
  toolAccess       UserToolAccess[]
  wishlist         Wishlist[]

  @@index([role])
  @@index([staffRole])
  @@index([createdAt])
}

/// Sellable clothing SKU; inventory and merchandising.
model Product {
  id              String          @id @default(cuid())
  /// Display name.
  name            String
  /// URL segment; unique for SEO and routing.
  slug            String          @unique
  /// Long description (HTML or markdown from CMS later).
  description     String
  /// Unit price in major currency units (e.g. USD).
  price           Decimal         @db.Decimal(10, 2)
  category        ProductCategory
  /// Cloudinary (or CDN) URLs, ordered gallery.
  images          String[]
  /// Available sizes (e.g. "S", "M", "L").
  sizes           String[]
  /// Available color labels or codes.
  colors          String[]
  /// Stock on hand (simple model; multi-warehouse can split later).
  stock           Int             @default(0)
  /// Homepage / collection highlights.
  featured        Boolean         @default(false)
  /// Visible in catalog when true (live listing).
  published       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  stripeProductId String?         @unique
  stripePriceId   String?         @unique
  /// Hidden from storefront; kept for history / admin (soft lifecycle).
  archived        Boolean         @default(false)
  /// Tags, season, material JSON — useful for search and future AI catalog understanding.
  metadata        Json?
  /// Optional merchant SKU / barcode.
  sku             String?         @unique
  /// Shipping weight (grams); nullable until fulfillment integration.
  weightGrams     Int?
  orderItems      OrderItem[]
  wishlist        Wishlist[]

  @@index([category, published, archived])
  @@index([featured, published, archived])
  @@index([published, archived, createdAt])
}

/// Digital product: self-improvement app, calculator, course shell, etc.
model Tool {
  id              String                 @id @default(cuid())
  name            String
  slug            String                 @unique
  description     String
  price           Decimal                @db.Decimal(10, 2)
  accessType      ToolAccessType
  /// Icon URL or Lucide name key.
  icon            String?
  published       Boolean                @default(false)
  featured        Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  stripeProductId String?                @unique
  stripePriceId   String?                @unique
  /// In-dashboard route or external app URL for iframe/deep link.
  appPath         String?                @db.VarChar(512)
  /// Tool capabilities, API version, feature flags for AI agents.
  metadata        Json?
  orderItems      OrderItem[]
  plans           SubscriptionPlanTool[]
  userAccess      UserToolAccess[]
  wishlist        Wishlist[]

  @@index([published, accessType])
  @@index([featured, published])
}

/// Checkout / fulfillment header. Supports registered users and guest checkout.
model Order {
  id                      String           @id @default(cuid())
  /// Registered buyer; null for pure guest orders.
  userId                  String?
  /// Lifecycle for physical fulfillment; digital items may skip to DELIVERED in app logic.
  status                  OrderStatus      @default(PENDING)
  paymentStatus           PaymentStatus    @default(PENDING)
  /// Grand total charged (sum of line items + tax/shipping when you add them).
  totalAmount             Decimal          @db.Decimal(10, 2)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  stripePaymentIntentId   String?          @unique
  /// Guest contact when `userId` is null.
  guestEmail              String?
  guestName               String?
  /// Idempotent payment retries / Stripe idempotency key.
  idempotencyKey          String?          @unique
  /// Raw webhook payload ids, discount codes, AI-assisted order notes (future).
  metadata                Json?
  /// Shipping snapshot (JSON: address lines, country, phone) for physical lines.
  shippingAddress         Json?
  stripeCheckoutSessionId String?          @unique
  user                    User?            @relation(fields: [userId], references: [id])
  items                   OrderItem[]
  toolAccessGrants        UserToolAccess[]

  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@index([createdAt])
  @@index([guestEmail])
}

/// Single line in an order (either a physical variant or a digital tool).
model OrderItem {
  id        String        @id @default(cuid())
  orderId   String
  type      OrderItemType
  productId String?
  toolId    String?
  quantity  Int           @default(1)
  /// Unit price at purchase time (historical).
  price     Decimal       @db.Decimal(10, 2)
  size      String?
  color     String?
  /// Per-line metadata: bundle id, personalization text, AI-generated SKUs, etc.
  metadata  Json?
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?      @relation(fields: [productId], references: [id])
  tool      Tool?         @relation(fields: [toolId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([toolId])
}

/// Sellable recurring plan (e.g. “KONIK Premium”).
model SubscriptionPlan {
  id              String                 @id @default(cuid())
  /// Unique plan code / display name.
  name            String                 @unique
  description     String
  price           Decimal                @db.Decimal(10, 2)
  /// Billing interval: "month" | "year" (Stripe price interval).
  interval        String                 @default("month")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  stripeProductId String?                @unique
  stripePriceId   String?                @unique
  /// Whether new purchases are allowed (grandfather existing subs).
  active          Boolean                @default(true)
  metadata        Json?
  /// Sort order on pricing page.
  sortOrder       Int                    @default(0)
  /// Maps to app tier for role upgrades and analytics.
  tier            SubscriptionPlanTier   @default(SUBSCRIBER)
  subscriptions   Subscription[]
  tools           SubscriptionPlanTool[]

  @@index([tier, active])
  @@index([active, sortOrder])
}

/// Tools included in a plan (many-to-many).
model SubscriptionPlanTool {
  planId String
  toolId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tool   Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([planId, toolId])
  @@index([toolId])
}

/// User’s subscription instance (Stripe subscription). Multiple rows per user = history or add-ons.
model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  startDate            DateTime           @default(now())
  endDate              DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stripeSubscriptionId String?            @unique
  cancelAtPeriodEnd    Boolean            @default(false)
  /// Stripe current_period_end mirror for access checks.
  currentPeriodEnd     DateTime?
  metadata             Json?
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([planId])
  @@index([status, currentPeriodEnd])
}

/// Effective entitlement: purchased, granted, or via plan. App checks this + active Subscription.
model UserToolAccess {
  id        String           @id @default(cuid())
  userId    String
  toolId    String
  /// When access was granted.
  grantedAt DateTime         @default(now())
  /// Null = no expiry (lifetime / until revoked). Subscriptions may set aligned expiry.
  expiresAt DateTime?
  /// Optional link to the order that unlocked this tool.
  orderId   String?
  /// Origin of access for support and revocation.
  source    ToolAccessSource @default(PURCHASE)
  order     Order?           @relation(fields: [orderId], references: [id])
  tool      Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId, expiresAt])
  @@index([toolId])
  @@index([source])
  @@index([orderId])
}

model DiscountCode {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  percentOff     Int?
  amountOff      Decimal?  @db.Decimal(10, 2)
  currency       String    @default("usd")
  active         Boolean   @default(true)
  maxRedemptions Int?
  redeemCount    Int       @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  metadata       Json?
}

model MarketingCampaign {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  active      Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  metadata    Json?
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

/// Access / monetization tier. SUBSCRIBER · PREMIUM · VIP should stay in sync with
/// `Subscription` + Stripe webhooks; ADMIN is staff-only; GUEST for lightweight identities.
enum UserRole {
  GUEST
  USER
  SUBSCRIBER
  PREMIUM
  VIP
  ADMIN
}

/// KONIK admin panel / operations role (orthogonal to customer `UserRole`).
enum StaffRole {
  SUPER_ADMIN
  ADMIN
  SALES
  SHIPPING
  MARKETING
}

enum ProductCategory {
  T_SHIRT
  HOODIE
  JACKET
  PANTS
  ACCESSORIES
  APPAREL
  FOOTWEAR
}

/// How the customer obtains ongoing access to a tool.
enum ToolAccessType {
  /// Lifetime / single purchase unlock.
  ONE_TIME
  /// Access while a qualifying subscription is active.
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderItemType {
  PRODUCT
  TOOL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

/// Commercial plan tier label — aligns with UserRole SUBSCRIBER / PREMIUM / VIP for UX.
enum SubscriptionPlanTier {
  SUBSCRIBER
  PREMIUM
  VIP
}

/// Why this user has access (audit + different expiry rules).
enum ToolAccessSource {
  /// Bought as ONE_TIME or completed checkout for tool line item.
  PURCHASE
  /// Included in an active subscription plan.
  SUBSCRIPTION_PLAN
  /// Admin / support manual grant.
  MANUAL_GRANT
  /// Time-limited promo or beta.
  TRIAL
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String?
  toolId    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
  tool      Tool?    @relation(fields: [toolId], references: [id])

  @@unique([userId, productId, toolId])
  @@index([userId])
  @@index([productId])
  @@index([toolId])
}

/// User engagement stage for dynamic homepage rendering.
enum Stage {
  COLD
  WARM
  HOT
}

/// Database-driven homepage section. Admin controls layout per stage.
model HomepageSection {
  id          String   @id @default(uuid())
  /// Which engagement stage this section appears in.
  stage       Stage
  /// Maps to COMPONENT_MAP key (e.g. HERO_CAROUSEL, IDENTITY, CTA).
  sectionType String
  /// Component-specific props as JSON.
  content     Json
  /// Optional hero image or video URL.
  mediaUrl    String?
  /// Display order within the stage layout.
  sortOrder   Int
  /// Toggle visibility without deleting.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stage, isActive, sortOrder])
}
